{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Throughput (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(turbosh_requests_total[1m])",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15 }
        }
      }
    },
    {
      "title": "Request Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(turbosh_request_duration_seconds_bucket[1m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(turbosh_request_duration_seconds_bucket[1m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(turbosh_request_duration_seconds_bucket[1m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Cache Hit Rate",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(turbosh_cache_hits_total[5m])) / clamp_min(sum(rate(turbosh_cache_hits_total[5m])) + sum(rate(turbosh_cache_misses_total[5m])), 1e-10)",
          "legendFormat": "Hit Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        }
      }
    },
    {
      "title": "Cache Operations (hits vs misses)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(turbosh_cache_hits_total[1m])",
          "legendFormat": "Hits/s",
          "refId": "A"
        },
        {
          "expr": "rate(turbosh_cache_misses_total[1m])",
          "legendFormat": "Misses/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 50 }
        }
      }
    },
    {
      "title": "Scheduler Saturation",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(turbosh_scheduler_active) / clamp_min(sum(turbosh_scheduler_capacity), 1)",
          "legendFormat": "Utilization",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      }
    },
    {
      "title": "ML Anomaly Decisions",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(turbosh_ml_blocks_total[1m])",
          "legendFormat": "Blocks/s",
          "refId": "A"
        },
        {
          "expr": "rate(turbosh_ml_throttles_total[1m])",
          "legendFormat": "Throttles/s",
          "refId": "B"
        },
        {
          "expr": "rate(turbosh_ml_allows_total[1m])",
          "legendFormat": "Allows/s",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Blocks/s" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "red", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Throttles/s" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "orange", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Allows/s" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "green", "mode": "fixed" }
              }
            ]
          }
        ]
      }
    },
    {
      "title": "ML Blocks (Total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 16 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(turbosh_ml_blocks_total)",
          "legendFormat": "Total Blocks",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "thresholds": { "steps": [{ "color": "red", "value": null }] }
        }
      }
    },
    {
      "title": "ML Throttles (Total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 16 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(turbosh_ml_throttles_total)",
          "legendFormat": "Total Throttles",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "thresholds": { "steps": [{ "color": "orange", "value": null }] }
        }
      }
    },
    {
      "title": "ML Allows (Total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 16 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(turbosh_ml_allows_total)",
          "legendFormat": "Total Allows",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "green", "mode": "fixed" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["turbosh", "monitoring", "ml"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "title": "turboSH — System Monitor",
  "uid": "turbosh-main",
  "version": 1
}
